# Production image for MULTI.
# Dev image (current Dockerfile) stays for local docker-compose.
#
# Build : docker build -f Dockerfile.prod -t ghcr.io/<org>/multi:<tag> .

# ────────── 1. Dependencies ──────────
FROM node:22-alpine AS deps
WORKDIR /app
COPY package.json package-lock.json ./
RUN npm ci --ignore-scripts

# ────────── 2. Builder ──────────
FROM node:22-alpine AS builder
WORKDIR /app
COPY --from=deps /app/node_modules ./node_modules
COPY . .

# Dummy env vars required at build time only — real ones come from k8s secrets at runtime.
ENV JWT_SECRET=build-time-dummy
ENV OPENCLAW_WEBHOOK_SECRET=build-time-dummy
ENV DATABASE_URL=postgresql://build:build@localhost:5432/build
ENV OPENROUTER_API_KEY=build-time-dummy
ENV NEXT_TELEMETRY_DISABLED=1

RUN npm run build

# ────────── 3. Runner ──────────
FROM node:22-alpine AS runner
WORKDIR /app

ENV NODE_ENV=production
ENV NEXT_TELEMETRY_DISABLED=1

# Non-root user
RUN addgroup --system --gid 1001 nodejs && adduser --system --uid 1001 nextjs

# Next.js standalone output bundles only what's needed.
COPY --from=builder --chown=nextjs:nodejs /app/.next/standalone ./
COPY --from=builder --chown=nextjs:nodejs /app/.next/static ./.next/static
COPY --from=builder --chown=nextjs:nodejs /app/public ./public

# Drizzle migrations (used by the separate migrate Job in k8s)
COPY --from=builder --chown=nextjs:nodejs /app/lib/db/migrations ./lib/db/migrations
COPY --from=builder --chown=nextjs:nodejs /app/scripts/migrate.ts ./scripts/migrate.ts
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/drizzle-orm ./node_modules/drizzle-orm
COPY --from=deps --chown=nextjs:nodejs /app/node_modules/postgres ./node_modules/postgres

# Docker CLI needed only if the orchestrator backend is `docker`.
# For k3s (production target), this is unused and can be dropped once migrated.
RUN apk add --no-cache docker-cli

USER nextjs
EXPOSE 3000
ENV PORT=3000
ENV HOSTNAME="0.0.0.0"

CMD ["node", "server.js"]
